# A set of files you probably don't want in your WordPress.org distribution.
# Anything matched here is excluded from the deployed plugin zip / SVN trunk.
# NOTE: vendor/ is intentionally NOT ignored — the plugin loads
# vendor/autoload.php (appsero/client) at runtime, so it must ship.

# Directories
.git/
.github/
.wordpress-org/
node_modules/
tests/
bin/

# Version control / CI / editor
.gitignore
.gitattributes
.distignore
.editorconfig
.travis.yml
.gitlab-ci.yml

# Dependency manifests (vendor/ ships, the manifests do not)
composer.json
composer.lock
package.json
package-lock.json
yarn.lock
phpcs.xml
phpcs.xml.dist
phpunit.xml
phpunit.xml.dist
webpack.config.js

# Docs not meant for the wp.org package
README.md
PERFORMANCE.md
CHANGELOG.md
CONTRIBUTING.md

# OS / misc cruft
.DS_Store
Thumbs.db
*.log
*.zip
